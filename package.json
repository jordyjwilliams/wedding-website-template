{
  "name": "wedding-website",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite dev --host --port 5174",
    "dev:netlify": "netlify dev",
    "build": "vite build",
    "preview": "vite preview --host",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest",
    "test:all": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy": "pnpm run build && netlify deploy --prod",
    "update-deps": "pnpm update && pnpm audit --fix update"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/nunito-sans": "^5.2.7",
    "@fontsource/raleway": "^5.2.8",
    "@fontsource/special-elite": "^5.2.8",
    "@iconify/svelte": "^5.2.1",
    "@internationalized/date": "^3.12.1",
    "@lottiefiles/dotlottie-svelte": "^0.10.2",
    "@lucide/svelte": "^1.16.0",
    "@netlify/blobs": "^10.7.8",
    "@netlify/functions": "^5.2.2",
    "@sveltejs/adapter-netlify": "^6.0.4",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.5.0",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "eslint": "^10.4.0",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "mode-watcher": "^1.1.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.55.9",
    "svelte-check": "^4.4.8",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.13",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@iconify/svelte": "^5.2.1",
    "@lottiefiles/dotlottie-svelte": "^0.10.2",
    "mode-watcher": "^1.1.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@11.1.3"
}
