{
	"version": 3,
	"routes": [
		{
			"src": ".*",
			"continue": true,
			"transforms": [
				{
					"type": "request.query",
					"op": "delete",
					"target": {
						"key": "__pathname"
					}
				}
			]
		},
		{
			"src": "/_app/immutable/.+",
			"headers": {
				"cache-control": "public, immutable, max-age=31536000"
			}
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "/_app/immutable/.+",
			"status": 404,
			"continue": false
		},
		{
			"src": "^/?(?:/__data.json)?$",
			"dest": "/"
		},
		{
			"src": "^/api/check-session/?(?:/__data.json)?$",
			"dest": "/api/check-session"
		},
		{
			"src": "^/api/logout-session/?(?:/__data.json)?$",
			"dest": "/api/logout-session"
		},
		{
			"src": "^/api/verify-passcode/?(?:/__data.json)?$",
			"dest": "/api/verify-passcode"
		},
		{
			"src": "^/home/?(?:/__data.json)?$",
			"dest": "/home"
		},
		{
			"src": "^/our-story/?(?:/__data.json)?$",
			"dest": "/our-story"
		},
		{
			"src": "^/rsvp/?(?:/__data.json)?$",
			"dest": "/rsvp"
		},
		{
			"src": "^/venue/?(?:/__data.json)?$",
			"dest": "/venue"
		},
		{
			"src": "^/wedding/?(?:/__data.json)?$",
			"dest": "/wedding"
		},
		{
			"src": "/.*",
			"dest": "/![-]/catchall"
		}
	],
	"overrides": {}
}