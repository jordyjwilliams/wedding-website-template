# Environment Variables Template
# Copy this file to .env for local development
# Add these variables in Netlify Dashboard for production

# Wedding passcode for guest access
WEDDING_PASSCODE=CHANGE_ME_STRONG_PASSCODE
SESSION_SIGNING_SECRET=CHANGE_ME_STRONG_SIGNING_SECRET

# Optional: Google Sheets Web App URL for RSVP submissions
VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/ID/exec
VITE_GOOGLE_SCRIPT_ACCOUNT_EMAIL=email@domain.me

# Optional: canonical public URL used in calendar invite details
# Default: origin of site requests unless overridden here.
# PUBLIC_SITE_URL=https://wedding-website-template.netlify.app

# If set true simulate delays better testing.
VITE_DEBUG_MODE=true
