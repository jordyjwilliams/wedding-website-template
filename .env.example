# Environment Variables Template
# Copy this file to .env for local development
# Add these variables in Netlify Dashboard for production

# Wedding passcode for guest access
WEDDING_PASSCODE=CHANGE_ME_STRONG_PASSCODE
SESSION_SIGNING_SECRET=CHANGE_ME_STRONG_SIGNING_SECRET

# Google Sheets Web App URL and shared secret for RSVP submissions
# Set NOTIFICATION_EMAIL directly in Apps Script → Project Settings → Script Properties
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/ID/exec
# This must match the value stored by `RSVP_SECRET` in the Google Apps Script code.
GOOGLE_SCRIPT_SECRET=CHANGE_ME_STRONG_RANDOM_SECRET

# Optional: canonical public URL used in calendar invite details
# Default: origin of site requests unless overridden here.
# VITE_PUBLIC_SITE_URL=https://wedding-website-template.netlify.app

# If set true simulate delays better testing.
VITE_DEBUG_MODE=true
