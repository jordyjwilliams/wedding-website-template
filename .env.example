# Environment Variables Template
# Copy this file to .env for local development
# Add these variables in Netlify Dashboard for production

# Wedding passcode for guest access
WEDDING_PASSCODE=nano

# Optional: Google Sheets Web App URL for RSVP submissions
VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/ID/exec
VITE_GOOGLE_SCRIPT_ACCOUNT_EMAIL=email@domain.me

# If set true simulate delays better testing.
VITE_DEBUG_MODE=true
